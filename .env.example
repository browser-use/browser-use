# ── browser-use original config ───────────────────────────────
BROWSER_USE_LOGGING_LEVEL=info
ANONYMIZED_TELEMETRY=true

# ── COMET — Google AI Studio ───────────────────────────────────
# Get your key -> https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── COMET — Chrome profile (Windows auto-detected if left empty)
# CHROME_USER_DATA_DIR=C:\Users\YourName\AppData\Local\Google\Chrome\User Data
# CHROME_PROFILE=Default

# ── COMET — Captcha solving (optional)
# CAPTCHA_API_KEY=your_2captcha_key_here
# CAPTCHA_SERVICE=2captcha
